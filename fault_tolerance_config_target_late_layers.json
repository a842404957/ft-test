{
  "model": {
    "name": "Res18",
    "num_classes": 10
  },
  "fault_injection": {
    "enabled": true,
    "fault_rate": 0.03,
    "fault_models": [
      "bit_flip"
    ],
    "target_layers": [
      "conv10.weight",
      "conv11.weight",
      "conv12.weight",
      "conv13.weight",
      "conv14.weight",
      "conv15.weight",
      "conv16.weight",
      "conv17.weight",
      "shortcut2.weight",
      "shortcut3.weight"
    ],
    "exclude_critical_layers": [
      "__last__"
    ],
    "random_seed": 42,
    "bit_flip_positions": "random",
    "bit_flip_ratio": 1.0
  },
  "simulation": {
    "batch_size": 128,
    "num_test_samples": 1000,
    "device": "cuda",
    "verbose": true
  },
  "report": {
    "output_dir": "./fault_tolerance_results/target_late_layers",
    "formats": [
      "json",
      "csv",
      "md"
    ]
  }
}
